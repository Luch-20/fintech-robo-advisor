    {
      "name": "3. API - 2 Stocks (ACB, BCM)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"investing\": [\n    {\"ticker\": \"ACB\", \"amount\": 1000000},\n    {\"ticker\": \"BCM\", \"amount\": 2000000}\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:5002/api",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5002",
          "path": ["api"]
        }
      }
    },
